# Environment variables for Spotify Advertising Admin Panel

# Database - Supabase Configuration
# DATABASE_URL: Use the "Transaction" pooler mode connection string
# This is used for regular queries (port 6543 for Supabase)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres"

# DATABASE_URL: Use the direct shared pooled connection string
# This is used for migrations (port 5432 for Supabase)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# NextAuth
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Alibaba Cloud OSS (for production file uploads)
# OSS_REGION="oss-ap-southeast-5"
# OSS_ACCESS_KEY_ID="your-key-id"
# OSS_ACCESS_KEY_SECRET="your-key-secret"
# OSS_BUCKET="your-app-media"
# OSS_CDN_DOMAIN="https://cdn.yourdomain.com"  # optional, omit to use direct OSS URL
